{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Configuration for upstream sync from azure-agentic-infraops to the workshop repo.",
  "source": {
    "owner": "jonathan-vella",
    "repo": "azure-agentic-infraops",
    "defaultRef": "main"
  },
  "target": {
    "owner": "jonathan-vella",
    "repo": "azure-agentic-infraops-workshop",
    "branchPrefix": "sync/upstream"
  },
  "autoSync": [
    ".github/agents/**",
    ".github/instructions/**",
    ".github/skills/**",
    ".github/prompts/**",
    ".github/ISSUE_TEMPLATE/**",
    ".github/PULL_REQUEST_TEMPLATE.md",
    ".github/CODEOWNERS",
    ".github/data/**",
    ".devcontainer/devcontainer.json",
    ".devcontainer/post-create.sh",
    ".devcontainer/update-tools.sh",
    ".vscode/**",
    "lefthook.yml",
    "commitlint.config.js",
    "requirements.txt",
    ".gitattributes",
    "CONTRIBUTING.md",
    "LICENSE",
    "scripts/*.mjs",
    "scripts/*.ps1",
    "scripts/workflow-generator/*.mjs",
    "scripts/workflow-generator/*.ps1",
    "scripts/workflow-generator/*.json",
    "scripts/workflow-generator/*.md",
    "mcp/azure-pricing-mcp/src/**",
    "mcp/azure-pricing-mcp/tests/**",
    "mcp/azure-pricing-mcp/docs/**",
    "mcp/azure-pricing-mcp/scripts/**",
    "mcp/azure-pricing-mcp/pyproject.toml",
    "mcp/azure-pricing-mcp/requirements.txt",
    "mcp/azure-pricing-mcp/README.md",
    "mcp/azure-pricing-mcp/LICENSE",
    "mcp/azure-pricing-mcp/Dockerfile",
    "mcp/azure-pricing-mcp/MANIFEST.in",
    "mcp/azure-pricing-mcp/INSTALL.md",
    "mcp/azure-pricing-mcp/CHANGELOG.md",
    "agent-output/_sample/**"
  ],
  "reviewSync": [
    ".github/copilot-instructions.md",
    ".devcontainer/README.md",
    ".gitignore",
    "pyproject.toml"
  ],
  "neverSync": [
    "README.md",
    "VERSION.md",
    "CHANGELOG.md",
    "CONTRIBUTORS.md",
    "package.json",
    ".github/skills/docs-writer/**",
    "microhack/**",
    "scripts/microhack/**",
    "docs/**",
    "infra/**",
    "Copilot-Processing.md",
    "agent-output/static-webapp/**",
    "agent-output/e2e-conductor-test/**",
    ".github/workflows/**",
    "mcp/azure-pricing-mcp/.archive/**",
    "mcp/azure-pricing-mcp/.github/**",
    "mcp/azure-pricing-mcp/.pre-commit-config.yaml",
    "mcp/azure-pricing-mcp/CONTRIBUTING.md",
    "scripts/workflow-generator/output/**"
  ]
}
